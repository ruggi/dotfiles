# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Editor cruft
*.swp
*.swo
*~
.vscode/
.idea/

# Local overrides — let users keep machine-specific tweaks untracked
*.local
*.local.*
.envrc.local

# Secrets — never stow these
.env
.env.*
*.key
*.pem
id_rsa
id_ed25519
**/.ssh/id_*
**/.ssh/known_hosts
**/.gnupg/private-keys-v1.d/

# Shell history & caches that some configs put in $XDG_CONFIG_HOME
.zsh_history
.bash_history
.lesshst
**/cache/
**/Cache/

# Stow's own conflict logs (rare but possible)
*.stow-conflicts
